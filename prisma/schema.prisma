generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String     @id @default(cuid())
  email         String     @unique
  passwordHash  String?
  createdAt     DateTime   @default(now())
  preferences   Json       @default("{}")
  emailVerified DateTime?
  image         String?
  name          String?
  isCreator     Boolean    @default(false)
  creatorBio    String?
  accounts      Account[]
  jobs          Job[]
  workflowJobs  WorkflowJob[]
  riffDraft     RiffDraft?
  sessions      Session[]
  wallet        Wallet?
  // Community
  createdTemplates    Template[]            @relation("CreatedTemplates")
  creatorPlans        SubscriptionPlan[]    @relation("CreatedPlans")
  subscriptions       UserSubscription[]
  favorites           UserFavorite[]
  assets              UserAsset[]
  templateExecutions  TemplateExecution[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Wallet {
  id        String   @id @default(cuid())
  userId    String   @unique
  balance   Decimal  @default(0.00)
  points    Int      @default(0)
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Transaction {
  id          String   @id @default(cuid())
  userId      String
  amount      Decimal
  type        String
  referenceId String?
  metadata    Json?
  createdAt   DateTime @default(now())
}

model RiffDraft {
  id           String   @id @default(cuid())
  userId       String   @unique
  nodesJson    Json     @default("[]")
  edgesJson    Json     @default("[]")
  viewportJson Json     @default("{\"x\":0,\"y\":0,\"zoom\":1}")
  updatedAt    DateTime @updatedAt
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Job {
  id            String   @id @default(cuid())
  userId        String
  nodeId        String
  nodeType      String
  status        String   @default("pending")
  result        Json?
  error         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  // Workflow execution support
  workflowJobId String?
  dependsOn     String[] @default([])
  inputData     Json?
  outputData    Json?
  
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  workflowJob   WorkflowJob? @relation(fields: [workflowJobId], references: [id], onDelete: SetNull)

  @@index([userId, status])
  @@index([workflowJobId])
  @@index([nodeId])
}

model WorkflowJob {
  id             String   @id @default(cuid())
  userId         String
  status         String   @default("pending")
  totalNodes     Int      @default(0)
  completedCount Int      @default(0)
  failedCount    Int      @default(0)
  results        Json     @default("{}")
  error          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobs           Job[]

  @@index([userId])
  @@index([status])
}

model ExecutionLog {
  id           String   @id @default(cuid())
  userId       String
  nodeType     String
  inputTokens  Int?
  outputTokens Int?
  creditCost   Int      @default(0)
  status       String
  createdAt    DateTime @default(now())
}

// ─────────────────────────────────────────────
// Community
// ─────────────────────────────────────────────

model Template {
  id              String    @id @default(cuid())
  creatorId       String
  name            String
  description     String?
  thumbnail       String?
  category        String    @default("general")
  tags            String[]  @default([])

  // Canvas 快照：存储在服务端，不暴露给客户端
  canvasSnapshot  Json      @default("{}")
  // 用户可调参数定义（label / type / required / options 等）
  parameters      Json      @default("[]")

  // 定价（积分制）
  pricingType     String    @default("free")   // free | pay_per_use | subscription
  priceInPoints   Int?                         // 每次执行消耗积分数

  // 统计
  executionsCount Int       @default(0)
  favoritesCount  Int       @default(0)
  rating          Decimal   @default(0)

  // 状态
  status          String    @default("draft")  // draft | published | archived
  isFeatured      Boolean   @default(false)
  publishedAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  creator           User                @relation("CreatedTemplates", fields: [creatorId], references: [id], onDelete: Cascade)
  subscriptionPlans SubscriptionPlan[]
  favorites         UserFavorite[]
  executions        TemplateExecution[]

  @@index([creatorId])
  @@index([status, publishedAt])
  @@index([category])
  @@index([isFeatured])
}

model SubscriptionPlan {
  id           String    @id @default(cuid())
  creatorId    String
  name         String
  description  String?
  price        Decimal
  billingCycle String    @default("monthly")  // monthly | annual
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  creator     User               @relation("CreatedPlans", fields: [creatorId], references: [id], onDelete: Cascade)
  templates   Template[]
  subscribers UserSubscription[]

  @@index([creatorId])
}

model UserSubscription {
  id        String   @id @default(cuid())
  userId    String
  planId    String
  creatorId String
  status    String   @default("active")  // active | paused | cancelled
  startedAt DateTime @default(now())
  endsAt    DateTime
  autoRenew Boolean  @default(true)

  user User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan SubscriptionPlan @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@unique([userId, planId])
  @@index([userId])
  @@index([planId])
}

model UserFavorite {
  id         String   @id @default(cuid())
  userId     String
  templateId String
  addedAt    DateTime @default(now())

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  template Template @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@unique([userId, templateId])
  @@index([userId])
}

model TemplateExecution {
  id          String    @id @default(cuid())
  userId      String
  templateId  String
  creatorId   String
  inputParams Json      @default("{}")
  resultUrl   String?
  resultType  String?   // video | image | document | text
  costInPoints Int      @default(0)   // 本次执行消耗的积分
  status      String    @default("queued")  // queued | running | completed | failed
  startedAt   DateTime  @default(now())
  completedAt DateTime?

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  template Template @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([templateId])
  @@index([status])
}

model UserAsset {
  id               String   @id @default(cuid())
  userId           String
  name             String
  type             String   // video | image | document | text
  url              String
  size             Int?
  sourceExecutionId String?
  sourceTemplateId  String?
  starred          Boolean  @default(false)
  tags             String[] @default([])
  createdAt        DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, starred])
}
