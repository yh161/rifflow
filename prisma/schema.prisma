generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String     @id @default(cuid())
  email         String     @unique
  passwordHash  String?
  createdAt     DateTime   @default(now())
  preferences   Json       @default("{}")
  emailVerified DateTime?
  image         String?
  name          String?
  accounts      Account[]
  jobs          Job[]
  workflowJobs  WorkflowJob[]
  riffDraft     RiffDraft?
  sessions      Session[]
  wallet        Wallet?
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Wallet {
  id        String   @id @default(cuid())
  userId    String   @unique
  balance   Decimal  @default(0.00)
  points    Int      @default(0)
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Transaction {
  id          String   @id @default(cuid())
  userId      String
  amount      Decimal
  type        String
  referenceId String?
  metadata    Json?
  createdAt   DateTime @default(now())
}

model RiffDraft {
  id        String   @id @default(cuid())
  userId    String   @unique
  nodesJson Json     @default("[]")
  edgesJson Json     @default("[]")
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Job {
  id            String   @id @default(cuid())
  userId        String
  nodeId        String
  nodeType      String
  status        String   @default("pending")
  result        Json?
  error         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  // Workflow execution support
  workflowJobId String?
  dependsOn     String[] @default([])
  inputData     Json?
  outputData    Json?
  
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  workflowJob   WorkflowJob? @relation(fields: [workflowJobId], references: [id], onDelete: SetNull)

  @@index([userId, status])
  @@index([workflowJobId])
  @@index([nodeId])
}

model WorkflowJob {
  id             String   @id @default(cuid())
  userId         String
  status         String   @default("pending")
  totalNodes     Int      @default(0)
  completedCount Int      @default(0)
  failedCount    Int      @default(0)
  results        Json     @default("{}")
  error          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobs           Job[]

  @@index([userId])
  @@index([status])
}

model ExecutionLog {
  id           String   @id @default(cuid())
  userId       String
  nodeType     String
  inputTokens  Int?
  outputTokens Int?
  creditCost   Int      @default(0)
  status       String
  createdAt    DateTime @default(now())
}
